# Application
NODE_ENV=development
PORT=3000
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:5173
SITE_NAME=Eter Poetry
DEFAULT_META_TITLE=Eter Poetry
DEFAULT_META_DESCRIPTION=Discover audio posts and creator profiles on Eter Poetry.
DEFAULT_SHARE_IMAGE_URL=http://localhost:5173/images/default-share.jpg
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
SWAGGER_PATH=api/docs

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=eter

# Authentication
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_TTL=30d
JWT_REFRESH_HASH_SECRET=

# Auth Cookies
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SAME_SITE=lax
REFRESH_COOKIE_SECURE=false

# Password Reset
PASSWORD_RESET_TTL=1h
PASSWORD_RESET_TOKEN_SECRET=
PASSWORD_RESET_URL=
PASSWORD_RESET_REQUEST_COOLDOWN=10m

# Email Verification
EMAIL_VERIFICATION_TTL=24h
EMAIL_VERIFICATION_URL=
EMAIL_VERIFICATION_REQUEST_COOLDOWN=10m

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FRONTEND_AUTH_REDIRECT_URL=

# Mail
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_SENDER_EMAIL=
MAILJET_SENDER_NAME=Eter Poetry
MAIL_REQUEST_LIMIT_PER_HOUR=20
MAIL_REQUEST_LIMIT_PER_WEEK=100
MAIL_REQUEST_LIMIT_PER_MONTH=300

# Storage
FILE_STORAGE_DRIVER=local
S3_REGION=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# Posts
FREE_RECORDING_DURATION_LIMIT_MINUTES=7
PREMIUM_RECORDING_DURATION_LIMIT_MINUTES=15
GUEST_SESSION_COOKIE_DOMAIN=
GUEST_SESSION_COOKIE_SAME_SITE=lax
GUEST_SESSION_COOKIE_SECURE=false
POST_AUDIO_PROCESSING_CONCURRENCY=2
POST_AUDIO_PROCESSING_POLL_MS=5000
POST_AUDIO_PROCESSING_MAX_ATTEMPTS=5

# Payments
SUBSCRIPTION_PRICE_USD=5
PAYMENTS_API_BASE_URL=
# Provider API token sent in the X-Token header
PAYMENTS_API_TOKEN=
PAYMENTS_WEBHOOK_URL=

# Moderation
MAX_ACTIVE_VIOLATIONS_BEFORE_BLOCK=3

# Sitemap
SITEMAP_SHARD_SIZE=50000
SITEMAP_RECENT_POSTS_COUNT=5000
